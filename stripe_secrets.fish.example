# Copy this file to stripe_secrets.fish in the same folder (project root).
# stripe_secrets.fish is gitignored — do not commit real keys.
#
#   cp stripe_secrets.fish.example stripe_secrets.fish
#   # edit stripe_secrets.fish with your test keys from https://dashboard.stripe.com/apikeys

set -gx STRIPE_SECRET_KEY "sk_test_REPLACE_ME"
# Optional, for webhooks:
# set -gx STRIPE_WEBHOOK_SECRET "whsec_REPLACE_ME"
